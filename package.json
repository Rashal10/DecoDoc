{
  "name": "decodoc",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "DecoDoc — structured research paper analysis.",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "npm run build -w shared && npm run build -w server && npm run build -w client",
    "vercel-build": "npm run build -w shared && npm run build -w client",
    "test": "npm run build -w shared && npm run test -w shared && npm run test -w server && npm run test -w client",
    "lint": "eslint \"client/src/**/*.{ts,tsx}\" \"server/src/**/*.ts\" \"shared/src/**/*.ts\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "eslint": "^9.21.0",
    "prettier": "^3.4.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.26.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.62.0",
    "@rollup/rollup-linux-x64-musl": "4.62.0",
    "@rollup/rollup-win32-x64-msvc": "4.62.0"
  }
}
