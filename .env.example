# LLM generation (server only — never expose to the browser)
# Primary: Groq (recommended). Fallback: OpenRouter, then Gemini.
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=16384

# Optional OpenRouter fallback when Groq rate-limits
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# Gemini — used for embeddings (and optional generation fallback)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# CORS — set to your deployed Vercel URL
CLIENT_ORIGIN=https://your-app.vercel.app
# Optional: comma-separated extra origins (preview deployments, local dev)
CLIENT_ORIGINS=http://localhost:5173
# Allow any *.vercel.app origin (useful for preview deployments)
ALLOW_VERCEL_PREVIEWS=true

# Server
PORT=8787
DATABASE_URL=postgresql://decodoc:decodoc@localhost:5432/decodoc

# Auth (email/password + Google — no third-party dashboard required for basic login)
AUTH_JWT_SECRET=change-this-to-a-long-random-string-in-production
# Optional Google sign-in (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
API_PUBLIC_URL=http://localhost:8787

# Client (Vite — prefix with VITE_)
# VITE_API_BASE_URL=https://your-api.onrender.com

# Optional — avoids Semantic Scholar 429 rate limits on citation maps
SEMANTIC_SCHOLAR_API_KEY=
